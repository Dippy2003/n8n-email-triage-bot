# ==========================================================================
# .gitignore — keeps secrets and local junk out of GitHub
# ==========================================================================

# --- Secrets: NEVER commit real environment values ---
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
token.json

# --- n8n local data / mounted files ---
n8n-local-files/
n8n_data/
.n8n/

# --- Node.js (for scripts/test-groq.js) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~

# --- Logs ---
logs/
*.log
